local L=game:GetService("Lighting")
local T=workspace:FindFirstChildOfClass("Terrain")
local P=game:GetService("Players")
local R=game:GetService("RunService")
local S=game:GetService("Stats")
local LP=P.LocalPlayer

local function setCap(v)
pcall(function() setfpscap(v) end)
end

setCap(60)

pcall(function() settings().Rendering.QualityLevel=Enum.QualityLevel.Level01 end)

L.GlobalShadows=false
L.FogEnd=9e9
L.Brightness=1
L.ClockTime=12

for _,v in pairs(L:GetDescendants()) do
if v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("SunRaysEffect") then
v.Enabled=false
end
end

if T then
T.WaterWaveSize=0
T.WaterWaveSpeed=0
T.WaterReflectance=0
T.WaterTransparency=1
end

local function f(x)
if x:IsA("BasePart") then
x.Material=Enum.Material.SmoothPlastic
x.Reflectance=0
x.CastShadow=false
elseif x:IsA("Decal") or x:IsA("Texture") then
x.Transparency=1
elseif x:IsA("ParticleEmitter") or x:IsA("Trail") then
x.Enabled=false
elseif x:IsA("Explosion") then
x.BlastPressure=0
x.BlastRadius=0
elseif x:IsA("Fire") or x:IsA("Smoke") then
x.Enabled=false
elseif x:IsA("MeshPart") then
x.TextureID=""
end
end

for _,v in pairs(workspace:GetDescendants()) do f(v) end
workspace.DescendantAdded:Connect(f)

local gui=Instance.new("ScreenGui")
gui.ResetOnSpawn=false
gui.Parent=LP:WaitForChild("PlayerGui")

local blur=Instance.new("BlurEffect")
blur.Size=0
blur.Parent=L

local container=Instance.new("Frame")
container.Size=UDim2.new(0,400,0,200)
container.Position=UDim2.new(0.5,-200,0.5,-100)
container.BackgroundTransparency=1
container.Parent=gui

local title=Instance.new("TextLabel")
title.Size=UDim2.new(1,0,0.6,0)
title.BackgroundTransparency=1
title.Text="NIPCD"
title.Font=Enum.Font.GothamBold
title.TextScaled=true
title.TextColor3=Color3.new(1,1,1)
title.TextTransparency=1
title.Parent=container

local sub=Instance.new("TextLabel")
sub.Size=UDim2.new(1,0,0.4,0)
sub.Position=UDim2.new(0,0,0.6,0)
sub.BackgroundTransparency=1
sub.Text="• FPS UNLOCK\n• +FPS"
sub.Font=Enum.Font.Code
sub.TextScaled=true
sub.TextColor3=Color3.fromRGB(200,200,200)
sub.TextTransparency=1
sub.Parent=container

task.spawn(function()
for i=0,20 do blur.Size=i task.wait() end
for i=1,0,-0.05 do title.TextTransparency=i sub.TextTransparency=i task.wait() end
task.wait(0.6)
for i=0,1,0.05 do title.TextTransparency=i sub.TextTransparency=i task.wait() end
for i=20,0,-1 do blur.Size=i task.wait() end
container:Destroy()
blur:Destroy()
end)

local bar=Instance.new("Frame")
bar.Size=UDim2.new(0,420,0,40)
bar.Position=UDim2.new(0,8,0,8)
bar.BackgroundColor3=Color3.new(0,0,0)
bar.BackgroundTransparency=0.35
bar.BorderSizePixel=0
bar.Parent=gui

local layout=Instance.new("UIListLayout",bar)
layout.FillDirection=Enum.FillDirection.Horizontal
layout.Padding=UDim.new(0,6)

local function makeBtn(text,cap)
local b=Instance.new("TextButton")
b.Size=UDim2.new(0,70,1,0)
b.Text=text
b.Font=Enum.Font.GothamBold
b.TextSize=12
b.BackgroundColor3=Color3.fromRGB(20,20,20)
b.TextColor3=Color3.new(1,1,1)
b.Parent=bar
Instance.new("UICorner",b).CornerRadius=UDim.new(0,6)

b.MouseButton1Click:Connect(function()
for _,c in pairs(bar:GetChildren()) do
if c:IsA("TextButton") then
c.BackgroundColor3=Color3.fromRGB(20,20,20)
end
end
b.BackgroundColor3=Color3.fromRGB(0,120,255)
setCap(cap)
end)
end

makeBtn("MAX",9999)
makeBtn("120",120)
makeBtn("60",60)
makeBtn("30",30)

local stats=Instance.new("TextLabel")
stats.Size=UDim2.new(0,200,0,40)
stats.Position=UDim2.new(0,440,0,8)
stats.BackgroundTransparency=1
stats.Font=Enum.Font.Code
stats.TextSize=14
stats.TextXAlignment=Enum.TextXAlignment.Left
stats.TextColor3=Color3.fromRGB(0,255,120)
stats.Parent=gui

local btn=Instance.new("TextButton")
btn.Size=UDim2.new(0,40,0,40)
btn.Position=UDim2.new(0,10,1,-50)
btn.BackgroundColor3=Color3.fromRGB(20,20,20)
btn.Text="X"
btn.TextColor3=Color3.new(1,1,1)
btn.Font=Enum.Font.GothamBold
btn.TextSize=18
btn.Parent=gui
Instance.new("UICorner",btn).CornerRadius=UDim.new(1,0)

local visible=true
btn.MouseButton1Click:Connect(function()
visible=not visible
bar.Visible=visible
stats.Visible=visible
end)

local dragging=false
local dragInput,dragStart,startPos

btn.InputBegan:Connect(function(input)
if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
dragging=true
dragStart=input.Position
startPos=btn.Position
input.Changed:Connect(function()
if input.UserInputState==Enum.UserInputState.End then dragging=false end
end)
end
end)

btn.InputChanged:Connect(function(input)
if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then
dragInput=input
end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
if input==dragInput and dragging then
local delta=input.Position-dragStart
btn.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
end
end)

local function getPing()
local p=0
pcall(function()
p=math.floor(S.Network.ServerStatsItem["Data Ping"]:GetValue())
end)
return p
end

while true do
local dt=R.RenderStepped:Wait()
local fps=math.floor(1/dt)
local ms=math.floor(dt*1000)
local ping=getPing()

local color
if fps<=20 then
color=Color3.fromRGB(255,0,0)
elseif fps<=30 then
color=Color3.fromRGB(255,170,0)
else
color=Color3.fromRGB(0,255,120)
end

stats.TextColor3=color
stats.Text="FPS: "..fps.." | "..ms.."ms | "..ping.."ms"

task.wait(0.2)
end
